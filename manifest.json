{
  "manifest_version": 3,
  "name": "D2L → Notion Sync",
  "version": "1.3",
  "description": "Sync D2L Brightspace and Pearson MyLab assignments to your Notion database.",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation"],
  "host_permissions": [
    "https://*.brightspace.com/*",
    "https://*.desire2learn.com/*",
    "https://*.d2l.com/*",
    "https://mylabmastering.pearson.com/*",
    "https://*.pearson.com/*",
    "https://*.pearsoncmg.com/*",
    "https://api.notion.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "D2L → Notion Sync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.brightspace.com/*",
        "https://*.desire2learn.com/*",
        "https://*.d2l.com/*",
        "https://mylabmastering.pearson.com/*",
        "https://*.pearson.com/*",
        "https://*.pearsoncmg.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "icons": {
    "2000": "icon2000.png"
}
}
