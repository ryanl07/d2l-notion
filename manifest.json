{
  "manifest_version": 3,
  "name": "D2L → Notion Sync",
  "version": "1.2",
  "description": "Sync D2L Brightspace assignments to your Notion database.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.brightspace.com/*",
    "https://*.desire2learn.com/*",
    "https://*.d2l.com/*",
    "https://api.notion.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "D2L → Notion Sync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.brightspace.com/*",
        "https://*.desire2learn.com/*",
        "https://*.d2l.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
